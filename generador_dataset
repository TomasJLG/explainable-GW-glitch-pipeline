def sanity_check_dataset(Xmm: np.memmap, energies: np.memmap, t0s: List[float],
                          ifo: str, epoch: str, dur: float) -> Dict[str, Any]:
    """
    Verifica integridad del dataset antes de empaquetar.
    Retorna dict con resultados. Lanza ValueError si hay problemas críticos.
    """
    report = {}
    n = Xmm.shape[0]

    # 1. NaNs e Infs en imágenes
    nan_count = int(np.sum(np.isnan(Xmm)))
    inf_count = int(np.sum(np.isinf(Xmm)))
    report["nan_in_X"] = nan_count
    report["inf_in_X"] = inf_count
    if nan_count > 0 or inf_count > 0:
        raise ValueError(f"[SANITY FAIL] X contiene {nan_count} NaNs y {inf_count} Infs.")

    # 2. Rango dinámico de imágenes
    x_min = float(np.min(Xmm))
    x_max = float(np.max(Xmm))
    x_mean = float(np.mean(Xmm))
    report["X_min"] = x_min
    report["X_max"] = x_max
    report["X_mean"] = round(x_mean, 4)
    if x_min < -0.1 or x_max > 1.1:
        print(f"[SANITY WARN] Rango de X fuera de [0,1]: min={x_min:.4f}, max={x_max:.4f}")

    # 3. NaNs en energías
    nan_energy = int(np.sum(np.isnan(energies)))
    report["nan_in_log_energy"] = nan_energy
    if nan_energy > 0:
        raise ValueError(f"[SANITY FAIL] log_energy contiene {nan_energy} NaNs.")

    # 4. Distribución de energías (señal de salud del dataset)
    e_p10 = float(np.percentile(energies, 10))
    e_p50 = float(np.percentile(energies, 50))
    e_p90 = float(np.percentile(energies, 90))
    e_p99 = float(np.percentile(energies, 99))
    report["log_energy_p10"] = round(e_p10, 4)
    report["log_energy_p50"] = round(e_p50, 4)
    report["log_energy_p90"] = round(e_p90, 4)
    report["log_energy_p99"] = round(e_p99, 4)

    # 5. t0s dentro de rango GPS razonable
    t0_arr = np.array(t0s)
    t0_out_of_range = int(np.sum((t0_arr < 1e9) | (t0_arr > 2e9)))
    report["t0_out_of_range"] = t0_out_of_range
    if t0_out_of_range > 0:
        print(f"[SANITY WARN] {t0_out_of_range} t0s fuera de rango GPS razonable.")

    # 6. Varianza media por imagen (detecta imágenes planas/corruptas)
    var_per_image = np.var(Xmm.reshape(n, -1), axis=1)
    flat_images = int(np.sum(var_per_image < 1e-6))
    report["flat_images"] = flat_images
    if flat_images > n * 0.05:
        print(f"[SANITY WARN] {flat_images}/{n} imágenes con varianza < 1e-6 (posiblemente corruptas).")

    print(f"[SANITY OK] {ifo} {epoch} dur={dur}s | "
          f"X∈[{x_min:.3f},{x_max:.3f}] mean={x_mean:.3f} | "
          f"log_energy p50={e_p50:.3f} p99={e_p99:.3f} | "
          f"flat={flat_images}/{n}")

    return report


# ============================================================
# Scheduler (cola limitada + heartbeat)
# ============================================================

def iter_pending_jobs(done: np.ndarray, t0s: List[float], ifo: str, epoch: str, dur: float) -> Iterable:
    for i in range(len(done)):
        if not done[i]:
            yield (i, ifo, epoch, float(t0s[i]), float(dur), float(FLOW), float(FHIGH), int(FS))

def run_jobs_streaming(
    EXEC,
    jobs_iter: Iterable,
    Xmm: np.memmap,
    energy_mm: np.memmap,   # [FIX-2] nuevo parámetro
    done: np.ndarray,
    scale_dir: str,
    ckpt_path: str,
    ckpt: Dict[str, Any],
    t0s: List[float]
) -> None:
    errlog = os.path.join(scale_dir, "errors.log")
    pending: Dict[Any, int] = {}
    completed = ok_added = fail_added = 0
    jobs_iter = iter(jobs_iter)

    def submit_one() -> bool:
        try:
            jb = next(jobs_iter)
        except StopIteration:
            return False
        fut = EXEC.submit(worker_compute, jb)
        pending[fut] = jb[0]
        return True

    for _ in range(IN_FLIGHT):
        if not submit_one():
            break

    while pending:
        done_set, _ = wait(set(pending.keys()), timeout=HEARTBEAT_SECS, return_when=FIRST_COMPLETED)

        if not done_set:
            print(f"[HB] sin completados en {HEARTBEAT_SECS}s | done={int(done.sum())}/{len(done)} | in_flight={len(pending)}")
            continue

        for fut in done_set:
            _idx = pending.pop(fut)
            i, ok, X, log_energy, err = fut.result()  # [FIX-2]

            if ok and X is not None:
                Xmm[i] = X
                energy_mm[i] = log_energy  # [FIX-2]
                done[i] = True
                ok_added += 1
            else:
                fail_added += 1
                with open(errlog, "a", encoding="utf-8") as f:
                    f.write(f"{time.time():.0f}\tidx={i}\tt0={t0s[i]:.6f}\terr={err}\n")

            completed += 1
            submit_one()

            if (completed % CKPT_EVERY) == 0:
                Xmm.flush()
                energy_mm.flush()  # [FIX-2]
                save_done_mask(scale_dir, done)
                done_now = int(done.sum())
                ckpt.update({
                    "status": "running", "done": done_now, "target": len(done),
                    "ok_added_last": ok_added, "fail_added_last": fail_added,
                    "completed_in_run": completed, "in_flight": len(pending),
                    "updated_unix": time.time()
                })
                save_json_atomic(ckpt_path, ckpt)
                print(f"[CKPT] +{CKPT_EVERY} | done={done_now}/{len(done)} | ok+{ok_added} fail+{fail_added} | in_flight={len(pending)}")

    Xmm.flush()
    energy_mm.flush()  # [FIX-2]
    save_done_mask(scale_dir, done)
    done_now = int(done.sum())
    ckpt.update({
        "status": "ready_to_pack" if done_now == len(done) else "partial",
        "done": done_now, "target": len(done),
        "ok_added_last": ok_added, "fail_added_last": fail_added,
        "completed_in_run": completed, "in_flight": 0,
        "updated_unix": time.time()
    })
    save_json_atomic(ckpt_path, ckpt)


