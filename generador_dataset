def run_for_ifo_epoch(ifo: str, epoch_name: str, t_start: int, t_end: int, EXEC) -> None:
    print("\n============================================================")
    print(f"Procesando: {ifo} - {epoch_name} [{t_start}, {t_end}] | RUN={RUN_TAG}")
    print("============================================================")

    segs = query_science_segments(ifo, t_start, t_end)
    print(f"[INFO] Segmentos (open data) activos: {len(segs)}")

    for dur in SCALES:
        slug = safe_slug_scale(dur)
        scale_dir = os.path.join(OUT_ROOT, RUN_TAG, ifo, epoch_name, f"scale_{slug}")
        ensure_dir(scale_dir)

        ckpt_path = os.path.join(scale_dir, "checkpoint.json")
        ckpt = load_json(ckpt_path)
        for k, v in [("ifo", ifo), ("epoch", epoch_name), ("dur", dur),
                     ("fs", FS), ("flow", FLOW), ("fhigh", FHIGH),
                     ("target_shape", TARGET_SHAPE), ("run_tag", RUN_TAG)]:
            ckpt.setdefault(k, v)

        out_npz = final_npz_path(scale_dir, ifo, epoch_name, dur, RUN_TAG)

        # [FIX-5] Advertencia documentada para escala 0.25s
        edge = effective_edge_crop(dur)
        effective_dur = dur - 2 * edge
        print(f"\n--- Escala {dur}s | edge_crop={edge:.3f}s | ventana_efectiva={effective_dur:.3f}s ---")
        if effective_dur < 0.2:
            print(f"[WARN] Ventana efectiva={effective_dur:.3f}s es muy corta. "
                  f"Las imágenes de escala {dur}s pueden tener menor calidad de borde.")

        if os.path.exists(out_npz):
            print(f"[INFO] NPZ final ya existe: {os.path.basename(out_npz)} -> saltando.")
            ckpt.update({"status": "done", "final_npz": out_npz, "updated_unix": time.time()})
            save_json_atomic(ckpt_path, ckpt)
            continue

        eligible = segments_eligible_for_duration(segs, dur, pad=FETCH_PAD)
        if not eligible:
            print(f"[WARN] No hay segmentos elegibles para dur={dur}. Saltando.")
            ckpt.update({"status": "no_segments", "updated_unix": time.time()})
            save_json_atomic(ckpt_path, ckpt)
            continue

        seed = SEED + (hash((ifo, epoch_name, dur, RUN_TAG)) % 10_000_000)
        t0s = get_or_create_manifest(scale_dir, eligible, N_WINDOWS_PER_SCALE, dur, FETCH_PAD, seed)

        Xmm = open_or_create_memmap(scale_dir, N_WINDOWS_PER_SCALE, TARGET_SHAPE)
        energy_mm = open_or_create_energy_memmap(scale_dir, N_WINDOWS_PER_SCALE)  # [FIX-2]
        done = load_or_create_done_mask(scale_dir, N_WINDOWS_PER_SCALE)

        done_count = int(done.sum())
        remaining = N_WINDOWS_PER_SCALE - done_count
        print(f"[INFO] Hechos: {done_count}/{N_WINDOWS_PER_SCALE} | Restantes: {remaining}")

        if remaining > 0:
            ckpt.update({"status": "running", "done": done_count,
                         "target": N_WINDOWS_PER_SCALE, "updated_unix": time.time()})
            save_json_atomic(ckpt_path, ckpt)

            jobs_iter = iter_pending_jobs(done, t0s, ifo, epoch_name, dur)
            t0_run = time.time()
            run_jobs_streaming(EXEC, jobs_iter, Xmm, energy_mm, done,
                               scale_dir, ckpt_path, ckpt, t0s)
            t1_run = time.time()

            done_count = int(done.sum())
            ckpt.update({"last_run_seconds": t1_run - t0_run, "updated_unix": time.time()})
            save_json_atomic(ckpt_path, ckpt)
            print(f"[INFO] Fin cómputo escala {dur}s. done={done_count}/{N_WINDOWS_PER_SCALE}. "
                  f"Tiempo={t1_run - t0_run:.1f}s")

        done = load_or_create_done_mask(scale_dir, N_WINDOWS_PER_SCALE)
        if int(done.sum()) < N_WINDOWS_PER_SCALE:
            print(f"[WARN] Escala {dur}s incompleta. Re-ejecuta.")
            continue

        # [FIX-4] Sanity checks antes de empaquetar
        print(f"[SANITY] Verificando integridad antes de empaquetar...")
        Xmm = open_or_create_memmap(scale_dir, N_WINDOWS_PER_SCALE, TARGET_SHAPE)
        energy_mm = open_or_create_energy_memmap(scale_dir, N_WINDOWS_PER_SCALE)
        try:
            sanity_report = sanity_check_dataset(Xmm, energy_mm, t0s, ifo, epoch_name, dur)
        except ValueError as e:
            print(f"[SANITY FAIL] {e}. No se empaqueta. Re-ejecuta para rellenar huecos.")
            ckpt.update({"status": "sanity_failed", "error": str(e), "updated_unix": time.time()})
            save_json_atomic(ckpt_path, ckpt)
            continue

        print(f"[PACK] Generando NPZ final: {os.path.basename(out_npz)}")

        meta = {
            "ifo": ifo, "epoch": epoch_name, "dur": dur, "fs": FS,
            "flow": FLOW, "fhigh": FHIGH, "qrange": QRANGE, "mismatch": MISMATCH,
            "fetch_pad": FETCH_PAD, "edge_crop_max": EDGE_CROP_MAX,
            "effective_window_dur": dur - 2 * effective_edge_crop(dur),
            "target_shape": TARGET_SHAPE, "n_windows": N_WINDOWS_PER_SCALE,
            "run_tag": RUN_TAG,
            # [FIX-1] Documentar orden de preprocesado
            "preprocess_order": "bandpass -> whiten -> notch",
            "whiten_fftlength": WHITEN_FFTLEN,
            "whiten_overlap": WHITEN_OVERLAP,
            "notch_freqs_hz": NOTCH_FREQS,
            # [FIX-2] Documentar escalar de energía
            "log_energy_description": (
                "log1p(percentile(Q-transform, 90)) calculado antes de normalizar. "
                "Feature de anomalía para M1: valores altos indican ventanas energéticas."
            ),
            "log_energy_percentile": ENERGY_PERCENTILE,
            # [FIX-3] Documentar normalización
            "normalization": "per-window p99 divisor (preserves relative structure, not z-score)",
            # [FIX-4] Resultados de sanity check
            "sanity_check": sanity_report,
            "created_unix": time.time()
        }

        np.savez_compressed(
            out_npz,
            X=Xmm,
            t0=np.array(t0s, dtype=np.float64),
            log_energy=np.array(energy_mm, dtype=np.float32),  # [FIX-2]
            meta_json=np.array(json.dumps(meta, ensure_ascii=False))
        )

        ckpt.update({"status": "done", "final_npz": out_npz, "updated_unix": time.time()})
        save_json_atomic(ckpt_path, ckpt)
        print(f"[DONE] Escala {dur}s empaquetada -> {out_npz}")

        if CLEANUP_AFTER_PACK:
            cleanup_scale_temporals(scale_dir)


# ============================================================
# MAIN
# ============================================================

def main():
    ensure_dir(OUT_ROOT)

    if USE_THREADS_FALLBACK:
        Executor = ThreadPoolExecutor
        ex_kwargs = {"max_workers": MAX_WORKERS}
        print("[WARN] No hay 'fork'. Usando ThreadPoolExecutor.")
    else:
        Executor = ProcessPoolExecutor
        ex_kwargs = {"max_workers": MAX_WORKERS, "mp_context": CTX}
        print(f"[INFO] Usando ProcessPoolExecutor(fork) | max_workers={MAX_WORKERS} | in_flight={IN_FLIGHT}")

    with Executor(**ex_kwargs) as EXEC:
        try:
            warm = [EXEC.submit(ping) for _ in range(min(MAX_WORKERS, 4))]
            _ = [f.result(timeout=30) for f in warm]
            print("[INFO] Warmup workers OK.")
        except Exception as e:
            print(f"[WARN] Warmup falló: {e}. Continuando...")

        for epoch_name, (t_start, t_end) in EPOCHS.items():
            for ifo in IFOS:
                run_for_ifo_epoch(ifo, epoch_name, t_start, t_end, EXEC)

    print("\n============================================================")
    print("FIN. Output root:", OUT_ROOT)
    print("NPZ contiene: X (imágenes), t0 (tiempos GPS), log_energy (escalar anomalía), meta_json")
    print("============================================================")


main()