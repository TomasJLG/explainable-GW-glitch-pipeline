def query_science_segments(ifo: str, t_start: int, t_end: int, retries: int = 3):
    flag = f"{ifo}_DATA"
    last = None
    for k in range(retries):
        try:
            dq = DataQualityFlag.fetch_open_data(flag, t_start, t_end)
            return dq.active
        except Exception as e:
            last = e
            time.sleep(1.5 * (k + 1))
    print(f"[WARN] fetch_open_data({flag}) falló: {last}. Fallback: segmento completo.")
    return SegmentList([Segment(t_start, t_end)])

def segments_eligible_for_duration(segs, dur: float, pad: float) -> List[Tuple[float, float]]:
    need = dur + 2.0 * pad
    out = []
    for s in segs:
        a, b = float(s[0]), float(s[1])
        if (b - a) >= need:
            out.append((a, b))
    return out

def sample_windows_from_segments(
    segs_eligible: List[Tuple[float, float]],
    n: int,
    dur: float,
    pad: float,
    seed: int
) -> List[float]:
    rng = random.Random(seed)
    if not segs_eligible:
        return []
    lengths = [max(0.0, (b - a) - (dur + 2.0 * pad)) for (a, b) in segs_eligible]
    total = sum(lengths)
    if total <= 0:
        return []
    t0s = []
    for _ in range(n):
        r = rng.random() * total
        acc = 0.0
        chosen = segs_eligible[-1]
        for (seg, w) in zip(segs_eligible, lengths):
            acc += w
            if r <= acc:
                chosen = seg
                break
        a, b = chosen
        t0s.append(rng.uniform(a + pad, b - pad - dur))
    return t0s

def get_or_create_manifest(
    scale_dir: str,
    eligible: List[Tuple[float, float]],
    n_target: int,
    dur: float,
    pad: float,
    seed: int
) -> List[float]:
    manifest_path = os.path.join(scale_dir, "manifest.json")
    if os.path.exists(manifest_path):
        m = load_json(manifest_path)
        t0s = m.get("t0s", [])
        if isinstance(t0s, list) and len(t0s) == n_target:
            return [float(x) for x in t0s]
        print("[WARN] Manifest inválido. Regenerando.")
    t0s = sample_windows_from_segments(eligible, n_target, dur, pad, seed)
    if len(t0s) != n_target:
        raise RuntimeError(f"No pude muestrear {n_target} ventanas (solo {len(t0s)}).")
    save_json_atomic(manifest_path, {
        "n_target": n_target, "dur": dur, "pad": pad, "seed": seed,
        "created_unix": time.time(), "t0s": t0s
    })
    return t0s


